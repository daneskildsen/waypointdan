---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { Marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';

const DAILY_DIR = 'data/timeline/daily/';
const LOGSEQ_DIR = 'data/logseq/';

export async function getStaticPaths() {
  const files = fs.readdirSync('data/timeline/daily/');
  const datePattern = /^timeline-(\d{8})\.json$/;
  const params = [];
  for (const f of files) {
    const match = f.match(datePattern);
    if (match) {
      params.push({ params: { trip: 'brisbane2026', date: match[1] } });
    }
  }
  return params;
}

const { date, trip } = Astro.params;
const y = date.slice(0, 4);
const m = date.slice(4, 6);
const d = date.slice(6, 8);
const formattedDate = `${y}-${m}-${d}`;

const allDates = fs.readdirSync(DAILY_DIR)
  .map((f) => f.match(/^timeline-(\d{8})\.json$/))
  .filter(Boolean)
  .map((m) => m[1])
  .sort();
const currentIndex = allDates.indexOf(date);
const prevDate = currentIndex > 0 ? allDates[currentIndex - 1] : null;
const nextDate = currentIndex < allDates.length - 1 ? allDates[currentIndex + 1] : null;

const tripTag = trip.replace(/(\d+)$/, ' $1').replace(/([a-z])([A-Z])/g, '$1 $2');

const allEntries = await getCollection('diary');
const entry = allEntries.find((e) => e.data.trip === trip && e.data.date === date);
let Content = null;
let title = formattedDate;
let location_name = '';
let weather_temp = null;
let images = [];
if (entry) {
  const result = await render(entry);
  Content = result.Content;
  title = entry.data.title;
  location_name = entry.data.location_name;
  weather_temp = entry.data.weather_temp;
  images = entry.data.images ?? [];
}

const timelinePath = path.join(DAILY_DIR, `timeline-${date}.json`);
let coords = [];
let weatherMetrics = { maxTemp: null, minTemp: null, precipitation: null, weatherCode: null };
let photos = [];
try {
  const raw = fs.readFileSync(timelinePath, 'utf-8');
  const data = JSON.parse(raw);
  const segments = data.semanticSegments ?? [];
  for (const seg of segments) {
    const segPath = seg.timelinePath ?? [];
    for (const pt of segPath) {
      const p = pt.point ?? '';
      const coordMatch = p.match(/([\d.-]+)°\s*,\s*([\d.-]+)°/);
      if (coordMatch) {
        coords.push([parseFloat(coordMatch[1]), parseFloat(coordMatch[2])]);
      }
    }
  }
  const wm = data.weatherMetrics ?? {};
  weatherMetrics = {
    maxTemp: wm.maxTemp ?? null,
    minTemp: wm.minTemp ?? null,
    precipitation: wm.precipitation ?? null,
    weatherCode: wm.weatherCode ?? null,
  };
  photos = data.photos ?? [];
} catch {
  // timeline file not found or parse error — coords stays empty
}

function weatherLabel(code) {
  if (code === null || code === undefined) return { icon: 'help', label: '--' };
  if (code === 0) return { icon: 'wb_sunny', label: 'Sunny' };
  if (code >= 1 && code <= 3) return { icon: 'partly_cloudy_day', label: 'Partly Cloudy' };
  if (code >= 51 && code <= 57) return { icon: 'rainy_light', label: 'Drizzle' };
  if (code >= 61 && code <= 65) return { icon: 'rainy', label: 'Rain' };
  if (code >= 71 && code <= 77) return { icon: 'weather_snowy', label: 'Snow' };
  if (code >= 80 && code <= 82) return { icon: 'rainy', label: 'Rain Showers' };
  if (code >= 95 && code <= 99) return { icon: 'thunderstorm', label: 'Thunderstorm' };
  return { icon: 'help', label: `Code ${code}` };
}

const w = weatherLabel(weatherMetrics.weatherCode);

const logseqFilename = `${y}_${m}_${d}.md`;
const logseqPath = path.join(LOGSEQ_DIR, logseqFilename);
let hasLogseq = false;
let logseqHtml = '';
try {
  if (fs.existsSync(logseqPath)) {
    const raw = fs.readFileSync(logseqPath, 'utf-8');
    const marked = new Marked();
    logseqHtml = marked.parse(raw);
    hasLogseq = true;
  }
} catch {
  // logseq file read or parse error — hasLogseq stays false
}

// --- Calendar data ---
const TRIP_START_NUM = 20260421;
const TRIP_END_NUM = 20260613;
const weekdays = ['M', 'T', 'W', 'T', 'F', 'S', 'S'];

function getMondayOffset(year, month) {
  const dow = new Date(year, month - 1, 1).getDay();
  return dow === 0 ? 6 : dow - 1;
}

function daysInMonth(year, month) {
  return new Date(year, month, 0).getDate();
}

function dateNum(year, month, day) {
  return year * 10000 + month * 100 + day;
}

const calendarMonths = [
  { name: 'April', year: 2026, month: 4 },
  { name: 'May', year: 2026, month: 5 },
  { name: 'June', year: 2026, month: 6 },
].map(m => {
  const totalDays = daysInMonth(m.year, m.month);
  const offset = getMondayOffset(m.year, m.month);
  const prevM = m.month === 1 ? 12 : m.month - 1;
  const prevY = m.month === 1 ? m.year - 1 : m.year;
  const prevTotal = daysInMonth(prevY, prevM);
  const nextM = m.month === 12 ? 1 : m.month + 1;
  const nextY = m.month === 12 ? m.year + 1 : m.year;
  const days = [];

  for (let i = 0; i < offset; i++) {
    days.push({ day: prevTotal - offset + 1 + i, muted: true, active: false });
  }
  for (let d = 1; d <= totalDays; d++) {
    const num = dateNum(m.year, m.month, d);
    const inRange = num >= TRIP_START_NUM && num <= TRIP_END_NUM;
    days.push({ day: d, muted: !inRange, active: num === parseInt(date), dateNum: num, inRange });
  }
  const remaining = (7 - (days.length % 7)) % 7;
  for (let i = 1; i <= remaining; i++) {
    days.push({ day: i, muted: true, active: false });
  }

  return { ...m, days };
});
const currentDateNum = parseInt(date);
---

<BaseLayout>
  <header class="fixed top-0 w-full z-50 flex justify-between items-center px-margin-page h-16 bg-background border-b border-outline-variant">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 flex-none bg-primary rounded-full flex items-center justify-center text-on-primary">
        <span class="material-symbols-outlined">explore</span>
      </div>
      <a href="/trips/" class="font-headline-md text-headline-md text-primary hover:opacity-80 transition-opacity">Waypoint Dan</a>
    </div>
    <div class="hidden md:flex flex-1 max-w-md mx-8">
      <div class="relative w-full">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
        <input class="w-full bg-surface-container-low border-none rounded-full pl-10 pr-4 py-2 focus:ring-2 focus:ring-primary text-body-md" placeholder="Search entries..." type="text">
      </div>
    </div>
    <div class="flex items-center gap-4">
      <button class="material-symbols-outlined p-2 hover:bg-surface-container-low transition-colors rounded-full">light_mode</button>
      <div class="flex items-center gap-2 text-primary font-bold">
        <a href={prevDate ? `/trips/${trip}/${prevDate}/` : '#'} class="material-symbols-outlined cursor-pointer hover:bg-surface-container-low rounded-full p-1 transition-colors" aria-label="Previous entry">chevron_left</a>
        <button id="cal-toggle" class="material-symbols-outlined cursor-pointer hover:bg-surface-container-low rounded-full p-1 transition-colors" aria-label="Toggle calendar" aria-expanded="false">event</button>
        <a href={nextDate ? `/trips/${trip}/${nextDate}/` : '#'} class="material-symbols-outlined cursor-pointer hover:bg-surface-container-low rounded-full p-1 transition-colors" aria-label="Next entry">chevron_right</a>
      </div>
    </div>
  </header>

  <main class="pt-16 min-h-screen pb-24">
    <section id="cal-section" class="hidden w-full bg-surface-container-low border-b border-outline-variant px-margin-page overflow-x-auto hide-scrollbar py-4">
      <div class="max-w-[1120px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
        {calendarMonths.map(month => (
          <div>
            <div class="flex justify-between items-center mb-2">
              <h3 class="font-label-sm uppercase tracking-widest text-primary font-semibold">{month.name} {month.year}</h3>
            </div>
            <div class="grid grid-cols-7 gap-1 mb-1 text-center text-[10px] font-bold text-on-surface-variant uppercase tracking-wider">
              {weekdays.map(d => <span class="py-0.5">{d}</span>)}
            </div>
            <div class="calendar-grid gap-0.5">
              {month.days.map(d => d.inRange ? (
                <a href={`/trips/${trip}/${d.dateNum}/`} class={`calendar-day${d.active ? ' active' : ''} no-underline text-on-surface`}>{d.day}</a>
              ) : (
                <span class="calendar-day muted cursor-default">{d.day}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
    <section class="relative w-full h-[400px] bg-surface-variant overflow-hidden" id="map" style="height: 400px; width: 100%;"></section>

    <section class="relative px-margin-page -mt-[20px] z-10">
      <div class="max-w-[1120px] mx-auto bg-white rounded-xl shadow-sm border border-outline-variant p-10 md:p-16">
        <div class="mb-10">
          <div class="flex items-center gap-2 mb-4">
            <span class="px-3 py-1 bg-surface-container text-on-secondary-container font-label-sm rounded-full">#{tripTag.replace(/\s+/g, '')}</span>
          </div>
          <h1 class="font-display-lg text-display-lg text-primary mb-2">{title}</h1>
          <p class="font-label-sm text-on-surface-variant uppercase tracking-widest">{formattedDate} &bull; {location_name}</p>
        </div>
        {hasLogseq ? (
        <div class="space-y-stack-lg">
          <div class="diary-line pl-8 prose" set:html={logseqHtml}></div>
        </div>
        ) : (
        <div class="space-y-stack-lg">
          <div class="diary-line pl-8">
            <div class="bg-surface-container-low rounded-xl border border-dashed border-outline-variant p-8 text-center">
              <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-3">edit_note</span>
              <p class="font-body-lg text-on-surface-variant">Add a logseq entry for <span class="font-semibold text-primary">{formattedDate}</span></p>
            </div>
          </div>
        </div>
        )}
      </div>
    </section>

    {photos.length > 0 && (
      <section class="mt-stack-lg px-margin-page" id="gallery-section">
        <div class="max-w-[1120px] mx-auto">
          <h2 class="font-headline-md text-headline-md text-primary mb-6">Gallery</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3" id="gallery-grid">
            {photos.map((photo, i) => (
              <button
                class="group aspect-square overflow-hidden rounded-xl border border-outline-variant bg-surface-container-low focus:outline-none focus:ring-2 focus:ring-primary"
                data-index={i}
                data-src={photo.url}
                aria-label="Open photo"
              >
                <img
                  class="w-full h-full object-cover transition-all duration-300 group-hover:scale-105 group-hover:opacity-90"
                  src={photo.url}
                  alt=""
                  loading="lazy"
                />
              </button>
            ))}
          </div>
        </div>
      </section>
    )}

    <div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90" role="dialog" aria-modal="true" aria-label="Photo lightbox">
      <button id="lb-close" class="absolute top-4 right-4 z-10 w-10 h-10 rounded-full bg-black/40 flex items-center justify-center text-white hover:bg-black/60 transition-colors" aria-label="Close lightbox">
        <span class="material-symbols-outlined text-2xl">close</span>
      </button>
      <button id="lb-prev" class="absolute left-4 top-1/2 -translate-y-1/2 z-10 w-12 h-12 rounded-full bg-black/40 flex items-center justify-center text-white hover:bg-black/60 transition-colors" aria-label="Previous photo">
        <span class="material-symbols-outlined text-3xl">chevron_left</span>
      </button>
      <button id="lb-next" class="absolute right-4 top-1/2 -translate-y-1/2 z-10 w-12 h-12 rounded-full bg-black/40 flex items-center justify-center text-white hover:bg-black/60 transition-colors" aria-label="Next photo">
        <span class="material-symbols-outlined text-3xl">chevron_right</span>
      </button>
      <img id="lb-img" class="max-w-[90vw] max-h-[90vh] object-contain rounded-lg shadow-2xl" alt="" />
    </div>

    <section class="mt-stack-lg px-margin-page pb-12">
      <div class="max-w-[1120px] mx-auto">
        <h2 class="font-headline-md text-headline-md text-primary mb-6">Weather report</h2>
        <div class="bg-surface-container-low rounded-xl border border-outline-variant p-6 flex flex-wrap items-center gap-8 md:gap-16">
          <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-4xl text-primary">{w.icon}</span>
            <div>
              <p class="font-headline-md text-primary">{w.label}</p>
              <p class="font-label-sm text-on-surface-variant">{location_name}</p>
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <p class="font-label-sm text-on-surface-variant uppercase tracking-widest">Max Temp</p>
            <p class="font-body-lg text-primary font-semibold">{weatherMetrics.maxTemp !== null ? `${weatherMetrics.maxTemp}°C` : '--'}</p>
          </div>
          <div class="flex flex-col gap-1">
            <p class="font-label-sm text-on-surface-variant uppercase tracking-widest">Min Temp</p>
            <p class="font-body-lg text-primary font-semibold">{weatherMetrics.minTemp !== null ? `${weatherMetrics.minTemp}°C` : '--'}</p>
          </div>
          <div class="flex flex-col gap-1">
            <p class="font-label-sm text-on-surface-variant uppercase tracking-widest">Rain</p>
            <p class="font-body-lg text-primary font-semibold">{weatherMetrics.precipitation !== null ? `${weatherMetrics.precipitation} mm` : '--'}</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter-grid mt-stack-lg">
          {prevDate ? (
            <a href={`/trips/${trip}/${prevDate}/`} class="group relative h-48 overflow-hidden rounded-xl border border-outline-variant transition-all hover:shadow-lg">
              <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent"></div>
              <div class="absolute bottom-4 left-6">
                <p class="font-label-sm text-on-primary-container/80 uppercase tracking-widest mb-1">Previous</p>
                <h4 class="font-headline-md text-on-primary">{prevDate.slice(0,4)}-{prevDate.slice(4,6)}-{prevDate.slice(6,8)}</h4>
              </div>
            </a>
          ) : (
            <div></div>
          )}
          {nextDate ? (
            <a href={`/trips/${trip}/${nextDate}/`} class="group relative h-48 overflow-hidden rounded-xl border border-outline-variant transition-all hover:shadow-lg">
              <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent"></div>
              <div class="absolute bottom-4 left-6">
                <p class="font-label-sm text-on-primary-container/80 uppercase tracking-widest mb-1">Next</p>
                <h4 class="font-headline-md text-on-primary">{nextDate.slice(0,4)}-{nextDate.slice(4,6)}-{nextDate.slice(6,8)}</h4>
              </div>
            </a>
          ) : (
            <div></div>
          )}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const thumbs = document.querySelectorAll('#gallery-grid button');
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lb-img');
  const lbClose = document.getElementById('lb-close');
  const lbPrev = document.getElementById('lb-prev');
  const lbNext = document.getElementById('lb-next');
  const sources = Array.from(thumbs).map((btn) => btn.dataset.src);
  let current = -1;

  function openLightbox(index) {
    current = index;
    lbImg.src = sources[current];
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    document.body.style.overflow = '';
    current = -1;
  }

  function prevPhoto() {
    if (sources.length === 0) return;
    current = (current - 1 + sources.length) % sources.length;
    lbImg.src = sources[current];
  }

  function nextPhoto() {
    if (sources.length === 0) return;
    current = (current + 1) % sources.length;
    lbImg.src = sources[current];
  }

  thumbs.forEach((btn) => {
    btn.addEventListener('click', () => openLightbox(parseInt(btn.dataset.index)));
  });

  lbClose.addEventListener('click', closeLightbox);
  lbPrev.addEventListener('click', prevPhoto);
  lbNext.addEventListener('click', nextPhoto);

  lb.addEventListener('click', (e) => {
    if (e.target === lb) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (!lb.classList.contains('hidden')) {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') prevPhoto();
      if (e.key === 'ArrowRight') nextPhoto();
    }
  });

  const calToggle = document.getElementById('cal-toggle');
  const calSection = document.getElementById('cal-section');
  if (calToggle && calSection) {
    calToggle.addEventListener('click', () => {
      const isHidden = calSection.classList.toggle('hidden');
      calToggle.setAttribute('aria-expanded', !isHidden);
    });
  }
</script>

<script define:vars={{ coords }}>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('map');
    if (typeof L !== 'undefined' && container && coords.length > 0) {
      const map = L.map('map', {
        zoomControl: true,
        attributionControl: true,
      });

      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>, &copy; CARTO',
        subdomains: 'abcd',
        maxZoom: 20,
      }).addTo(map);

      const polyline = L.polyline(coords, {
        color: '#002045',
        weight: 4,
        opacity: 0.8,
        smoothFactor: 1,
      }).addTo(map);

      map.fitBounds(polyline.getBounds(), { padding: [40, 40] });
    }
  });
</script>

<style is:global>
  .prose {
    color: var(--color-on-background);
    font-size: 1.125rem;
    line-height: 1.8;
  }
  .prose > * + * {
    margin-top: 1.25em;
  }
  .prose p {
    margin-bottom: 0;
  }
  .prose h2, .prose h3 {
    color: var(--color-primary);
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .prose h2 { font-size: 1.375rem; margin-top: 2.25em; }
  .prose h3 { font-size: 1.125rem; margin-top: 1.75em; }
  .prose strong { color: var(--color-primary); font-weight: 600; }
  .prose img { border-radius: 0.5rem; border: 1px solid var(--color-outline-variant); max-width: 100%; }
  .prose ul, .prose ol { padding-left: 1.5rem; }
  .prose ul { list-style-type: disc; }
  .prose ol { list-style-type: decimal; }
  .prose li { margin-top: 0.5em; }
  .prose a { color: var(--color-primary); text-decoration: underline; text-underline-offset: 3px; }
  .prose blockquote {
    border-left: 2px solid var(--color-primary);
    padding-left: 1.25rem;
    font-style: italic;
    color: var(--color-on-surface-variant);
  }
  .prose hr {
    border: 0;
    border-top: 1px solid var(--color-outline-variant);
    margin-top: 2.5em;
    margin-bottom: 2.5em;
  }

  #map {
    z-index: 1;
  }
  #map .leaflet-control-attribution { font-size: 10px; color: var(--color-on-surface-variant); }
  #map .leaflet-control-zoom a { background: var(--color-surface-container-low); color: var(--color-primary); border-color: var(--color-outline-variant); }
</style>
