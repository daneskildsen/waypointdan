---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import fs from 'node:fs';

export async function getStaticPaths() {
  const entries = await getCollection('diary');
  return entries.map((entry) => ({
    params: {
      trip: entry.data.trip,
      date: entry.data.date,
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, date, location_name, weather_temp, images } = entry.data;

const y = date.slice(0, 4);
const m = date.slice(4, 6);
const d = date.slice(6, 8);
const formattedDate = `${y}-${m}-${d}`;

const allEntries = await getCollection('diary');
const sorted = allEntries.sort((a, b) => a.data.date.localeCompare(b.data.date));
const currentIndex = sorted.findIndex((e) => e.id === entry.id);
const prev = sorted[currentIndex - 1] ?? null;
const next = sorted[currentIndex + 1] ?? null;

const tripTag = entry.data.trip.replace(/(\d+)$/, ' $1').replace(/([a-z])([A-Z])/g, '$1 $2');

const timelinePath = `/home/daneskildsen/projects/waypointdan/data/timeline/daily/timeline-${date}.json`;
let coords = [];
try {
  const raw = fs.readFileSync(timelinePath, 'utf-8');
  const data = JSON.parse(raw);
  const segments = data.semanticSegments ?? [];
  for (const seg of segments) {
    const path = seg.timelinePath ?? [];
    for (const pt of path) {
      const p = pt.point ?? '';
      const match = p.match(/([\d.-]+)°\s*,\s*([\d.-]+)°/);
      if (match) {
        coords.push([parseFloat(match[1]), parseFloat(match[2])]);
      }
    }
  }
} catch {
  // timeline file not found or parse error — coords stays empty
}
---

<BaseLayout>
  <header class="fixed top-0 w-full z-50 flex justify-between items-center px-margin-page h-16 bg-background border-b border-outline-variant">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 flex-none bg-primary rounded-full flex items-center justify-center text-on-primary">
        <span class="material-symbols-outlined">explore</span>
      </div>
      <a href="/trips/" class="font-headline-md text-headline-md text-primary hover:opacity-80 transition-opacity">Waypoint Dan</a>
    </div>
    <div class="hidden md:flex flex-1 max-w-md mx-8">
      <div class="relative w-full">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
        <input class="w-full bg-surface-container-low border-none rounded-full pl-10 pr-4 py-2 focus:ring-2 focus:ring-primary text-body-md" placeholder="Search entries..." type="text">
      </div>
    </div>
    <div class="flex items-center gap-4">
      <button class="material-symbols-outlined p-2 hover:bg-surface-container-low transition-colors rounded-full">light_mode</button>
      <div class="flex items-center gap-2 text-primary font-bold">
        <a href={prev ? `/trips/${prev.data.trip}/${prev.data.date}/` : '#'} class="material-symbols-outlined cursor-pointer hover:bg-surface-container-low rounded-full p-1 transition-colors" aria-label="Previous entry">chevron_left</a>
        <a href="/trips/" class="material-symbols-outlined cursor-pointer hover:bg-surface-container-low rounded-full p-1 transition-colors" aria-label="All trips">event</a>
        <a href={next ? `/trips/${next.data.trip}/${next.data.date}/` : '#'} class="material-symbols-outlined cursor-pointer hover:bg-surface-container-low rounded-full p-1 transition-colors" aria-label="Next entry">chevron_right</a>
      </div>
    </div>
  </header>

  <main class="pt-16 min-h-screen pb-24">
    <section class="relative w-full h-[400px] bg-surface-variant overflow-hidden" id="map" style="height: 400px; width: 100%;"></section>

    <section class="relative px-margin-page -mt-[20px] z-10">
      <div class="max-w-[1120px] mx-auto bg-white rounded-xl shadow-sm border border-outline-variant p-10 md:p-16">
        <div class="mb-10">
          <div class="flex items-center gap-2 mb-4">
            <span class="px-3 py-1 bg-surface-container text-on-secondary-container font-label-sm rounded-full">#{tripTag.replace(/\s+/g, '')}</span>
          </div>
          <h1 class="font-display-lg text-display-lg text-primary mb-2">{title}</h1>
          <p class="font-label-sm text-on-surface-variant uppercase tracking-widest">{formattedDate} &bull; {location_name}</p>
        </div>
        <div class="space-y-stack-lg">
          <div class="diary-line pl-8 prose">
            <Content />
          </div>
        </div>
      </div>
    </section>

    {images.length > 0 && (
      <section class="mt-stack-lg px-margin-page">
        <div class="flex items-center justify-between mb-6 max-w-[1120px] mx-auto">
          <h2 class="font-headline-md text-headline-md text-primary">Trip Gallery</h2>
          <div class="flex gap-2">
            <button class="material-symbols-outlined p-2 border border-outline-variant rounded-full hover:bg-surface-container transition-colors" id="prevBtn">arrow_back</button>
            <button class="material-symbols-outlined p-2 border border-outline-variant rounded-full hover:bg-surface-container transition-colors" id="nextBtn">arrow_forward</button>
          </div>
        </div>
        <div class="flex gap-4 overflow-x-auto hide-scrollbar snap-x snap-mandatory pb-4 max-w-[1120px] mx-auto" id="carousel">
          {images.map((src) => (
            <div class="flex-none w-80 md:w-96 snap-start">
              <img class="w-full aspect-square object-cover rounded-xl border border-outline-variant" src={src} alt="Trip photo" loading="lazy" />
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="mt-stack-lg px-margin-page pb-12">
      <div class="max-w-[1120px] mx-auto">
        <h2 class="font-headline-md text-headline-md text-primary mb-6">Daily Weather</h2>
        <div class="bg-surface-container-low rounded-xl border border-outline-variant p-6 flex flex-wrap items-center gap-8 md:gap-16">
          <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-4xl text-primary">wb_sunny</span>
            <div>
              <p class="font-headline-md text-primary">Mostly Sunny</p>
              <p class="font-label-sm text-on-surface-variant">{location_name}</p>
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <p class="font-label-sm text-on-surface-variant uppercase tracking-widest">Temperature</p>
            <p class="font-body-lg text-primary font-semibold">{weather_temp}&deg;C</p>
          </div>
          <div class="flex flex-col gap-1">
            <p class="font-label-sm text-on-surface-variant uppercase tracking-widest">Date</p>
            <p class="font-body-lg text-primary font-semibold">{formattedDate}</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter-grid mt-stack-lg">
          {prev ? (
            <a href={`/trips/${prev.data.trip}/${prev.data.date}/`} class="group relative h-48 overflow-hidden rounded-xl border border-outline-variant transition-all hover:shadow-lg">
              <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent"></div>
              <div class="absolute bottom-4 left-6">
                <p class="font-label-sm text-on-primary-container/80 uppercase tracking-widest mb-1">Previous</p>
                <h4 class="font-headline-md text-on-primary">{prev.data.title}</h4>
              </div>
            </a>
          ) : (
            <div></div>
          )}
          {next ? (
            <a href={`/trips/${next.data.trip}/${next.data.date}/`} class="group relative h-48 overflow-hidden rounded-xl border border-outline-variant transition-all hover:shadow-lg">
              <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent"></div>
              <div class="absolute bottom-4 left-6">
                <p class="font-label-sm text-on-primary-container/80 uppercase tracking-widest mb-1">Next</p>
                <h4 class="font-headline-md text-on-primary">{next.data.title}</h4>
              </div>
            </a>
          ) : (
            <div></div>
          )}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const carousel = document.getElementById('carousel');
  const nextBtn = document.getElementById('nextBtn');
  const prevBtn = document.getElementById('prevBtn');

  if (carousel && nextBtn) {
    nextBtn.addEventListener('click', () => {
      carousel.scrollBy({ left: 350, behavior: 'smooth' });
    });
  }

  if (carousel && prevBtn) {
    prevBtn.addEventListener('click', () => {
      carousel.scrollBy({ left: -350, behavior: 'smooth' });
    });
  }
</script>

<script define:vars={{ coords }}>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('map');
    if (typeof L !== 'undefined' && container && coords.length > 0) {
      const map = L.map('map', {
        zoomControl: true,
        attributionControl: true,
      });

      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>, &copy; CARTO',
        subdomains: 'abcd',
        maxZoom: 20,
      }).addTo(map);

      const polyline = L.polyline(coords, {
        color: '#002045',
        weight: 4,
        opacity: 0.8,
        smoothFactor: 1,
      }).addTo(map);

      map.fitBounds(polyline.getBounds(), { padding: [40, 40] });
    }
  });
</script>

<style is:global>
  .prose {
    color: var(--color-on-background);
    font-size: 1.125rem;
    line-height: 1.8;
  }
  .prose > * + * {
    margin-top: 1.25em;
  }
  .prose p {
    margin-bottom: 0;
  }
  .prose h2, .prose h3 {
    color: var(--color-primary);
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .prose h2 { font-size: 1.375rem; margin-top: 2.25em; }
  .prose h3 { font-size: 1.125rem; margin-top: 1.75em; }
  .prose strong { color: var(--color-primary); font-weight: 600; }
  .prose img { border-radius: 0.5rem; border: 1px solid var(--color-outline-variant); max-width: 100%; }
  .prose ul, .prose ol { padding-left: 1.5rem; }
  .prose ul { list-style-type: disc; }
  .prose ol { list-style-type: decimal; }
  .prose li { margin-top: 0.5em; }
  .prose a { color: var(--color-primary); text-decoration: underline; text-underline-offset: 3px; }
  .prose blockquote {
    border-left: 2px solid var(--color-primary);
    padding-left: 1.25rem;
    font-style: italic;
    color: var(--color-on-surface-variant);
  }
  .prose hr {
    border: 0;
    border-top: 1px solid var(--color-outline-variant);
    margin-top: 2.5em;
    margin-bottom: 2.5em;
  }

  #map {
    z-index: 1;
  }
  #map .leaflet-control-attribution { font-size: 10px; color: var(--color-on-surface-variant); }
  #map .leaflet-control-zoom a { background: var(--color-surface-container-low); color: var(--color-primary); border-color: var(--color-outline-variant); }
</style>
