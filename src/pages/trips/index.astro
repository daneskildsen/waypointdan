---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout>
  <main class="min-h-screen pb-24">
    <section class="px-margin-page pt-20">
      <div class="max-w-[1120px] mx-auto">
        <h1 class="font-display-lg text-display-lg text-primary mb-2">Waypoint Dan: Dan's personal Travel Diary</h1>
        <p class="font-body-lg text-on-surface-variant mb-12">Entries for April 21 to June 13, 2026</p>

        <div class="grid gap-8">
          <a
            href="/trips/brisbane2026/20260421/"
            class="group block bg-white rounded-xl shadow-sm border border-outline-variant p-8 transition-all hover:shadow-lg hover:border-primary/30"
          >
            <div class="flex items-center justify-between">
              <div>
                <h2 class="font-headline-lg text-headline-lg text-primary mb-1 capitalize">Brisbane 2026</h2>
                <p class="font-label-sm text-on-surface-variant uppercase tracking-widest">Entries for April 21 to June 13, 2026</p>
              </div>
              <span class="text-3xl text-primary group-hover:translate-x-1 transition-transform">&rarr;</span>
            </div>
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
