---
import BaseLayout from '../layouts/BaseLayout.astro';

const tags = ['Australia', 'SoloTravel', 'Adrenaline'];

const months = [
  {
    name: 'April',
    year: 2026,
    days: [
      { day: 30, muted: true },
      { day: 31, muted: true },
      ...Array.from({ length: 30 }, (_, i) => ({ day: i + 1 })),
      { day: 1, muted: true },
      { day: 2, muted: true },
      { day: 3, muted: true },
    ],
  },
  {
    name: 'May',
    year: 2026,
    days: [
      { day: 27, muted: true },
      { day: 28, muted: true },
      { day: 29, muted: true },
      { day: 30, muted: true },
      ...Array.from({ length: 31 }, (_, i) => ({ day: i + 1 })),
    ],
  },
  {
    name: 'June',
    year: 2026,
    days: [
      ...Array.from({ length: 13 }, (_, i) => ({ day: i + 1 })),
      { day: 14, active: true },
      ...Array.from({ length: 16 }, (_, i) => ({ day: i + 15 })),
      { day: 1, muted: true },
      { day: 2, muted: true },
      { day: 3, muted: true },
      { day: 4, muted: true },
      { day: 5, muted: true },
    ],
  },
];

const diaryParagraphs = [
  `The humidity of the Brisbane morning was already settling in by 8:00 AM as I approached the base of the Story Bridge. It's an imposing piece of steel\u2014a cantilever bridge that feels like the industrial heart of the city. I've always preferred seeing a city from its highest points, and today was about gaining that perspective.`,
  `Strapped into a safety harness, the ascent began. The rhythmic clinking of the carabiners against the metal railing became the soundtrack of the next hour. As we reached the summit, the city unfolded. To the west, the CBD skyscrapers glinted in the sunlight; to the east, the river snaked toward Moreton Bay.`,
  `Descending was faster, the adrenaline slowly giving way to a pleasant fatigue. I spent the rest of the afternoon wandering through the Kangaroo Point Cliffs, looking back up at where I had just been. Brisbane has this understated charm\u2014it doesn't demand your attention like Sydney, it invites you in quietly.`,
];

const galleryImages = [
  'https://placehold.co/400x400/e8eff1/002045?text=Photo+1',
  'https://placehold.co/400x400/e8eff1/002045?text=Photo+2',
  'https://placehold.co/400x400/e8eff1/002045?text=Photo+3',
  'https://placehold.co/400x400/e8eff1/002045?text=Photo+4',
];

const navCards = [
  { label: 'Previous', title: 'Day 4 - Kangaroo Point', image: 'https://placehold.co/560x192/e8eff1/002045?text=Previous' },
  { label: 'Next', title: 'Day 6 - Arrival in Brisbane CBD', image: 'https://placehold.co/560x192/e8eff1/002045?text=Next' },
];

const weekdays = ['M', 'T', 'W', 'T', 'F', 'S', 'S'];
---

<BaseLayout>
  <header class="fixed top-0 w-full z-50 flex justify-between items-center px-margin-page h-16 bg-background border-b border-outline-variant">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 flex-none bg-primary rounded-full flex items-center justify-center text-on-primary">
        <span class="material-symbols-outlined">explore</span>
      </div>
      <span class="font-headline-md text-headline-md text-primary">Waypoint Dan</span>
    </div>
    <div class="hidden md:flex flex-1 max-w-md mx-8">
      <div class="relative w-full">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
        <input class="w-full bg-surface-container-low border-none rounded-full pl-10 pr-4 py-2 focus:ring-2 focus:ring-primary text-body-md" placeholder="Search entries..." type="text">
      </div>
    </div>
    <div class="flex items-center gap-4">
      <button class="material-symbols-outlined p-2 hover:bg-surface-container-low transition-colors rounded-full">light_mode</button>
      <div class="flex items-center gap-2 text-primary font-bold">
        <span class="material-symbols-outlined cursor-pointer">chevron_left</span>
        <span class="material-symbols-outlined cursor-pointer">event</span>
        <span class="material-symbols-outlined cursor-pointer">chevron_right</span>
      </div>
    </div>
  </header>

  <main class="pt-16 min-h-screen pb-24">
    <section class="w-full bg-surface-container-low border-b border-outline-variant px-margin-page overflow-x-auto hide-scrollbar py-2">
      <div class="max-w-[1120px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-4">
        {months.map((month) => (
          <div>
            <div class="flex justify-between items-center mb-1">
              <h3 class="font-label-sm uppercase tracking-widest text-primary">{month.name} {month.year}</h3>
            </div>
            <div class="grid grid-cols-7 gap-2 mb-2 text-center text-[10px] font-bold text-on-surface-variant uppercase">
              {weekdays.map((d) => <span>{d}</span>)}
            </div>
            <div class="calendar-grid gap-1">
              {month.days.map((d) => {
                const cls = ['calendar-day'];
                if (d.muted) cls.push('muted');
                if (d.active) cls.push('active');
                return <div class={cls.join(' ')}>{d.day}</div>;
              })}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="relative w-full h-[400px] bg-surface-variant overflow-hidden map-inset">
      <div class="absolute inset-0 grayscale opacity-40 mix-blend-multiply" style="background-image: url('https://placehold.co/1120x400/e8eff1/002045?text=Brisbane+River'); background-size: cover; background-position: center;"></div>
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="text-primary/20 font-headline-lg text-[120px] select-none uppercase tracking-tighter opacity-10">Brisbane River</div>
      </div>
    </section>

    <section class="relative px-margin-page -mt-[20px] z-10">
      <div class="max-w-[1120px] mx-auto bg-white rounded-xl shadow-sm border border-outline-variant p-10 md:p-16">
        <div class="mb-10">
          <div class="flex items-center gap-2 mb-4">
            {tags.map((tag) => (
              <span class="px-3 py-1 bg-surface-container text-on-secondary-container font-label-sm rounded-full">#{tag}</span>
            ))}
          </div>
          <h1 class="font-display-lg text-display-lg text-primary mb-2">Day 5: Story Bridge Climb</h1>
          <p class="font-label-sm text-on-surface-variant uppercase tracking-widest">October 16, 2024 &bull; Brisbane, QLD</p>
        </div>
        <div class="space-y-stack-lg">
          {diaryParagraphs.map((paragraph) => (
            <div class="diary-line pl-8">
              <p class="font-body-lg text-body-lg leading-relaxed">{paragraph}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="mt-stack-lg px-margin-page">
      <div class="flex items-center justify-between mb-6 max-w-[1120px] mx-auto">
        <h2 class="font-headline-md text-headline-md text-primary">Trip Gallery</h2>
        <div class="flex gap-2">
          <button class="material-symbols-outlined p-2 border border-outline-variant rounded-full hover:bg-surface-container transition-colors" id="prevBtn">arrow_back</button>
          <button class="material-symbols-outlined p-2 border border-outline-variant rounded-full hover:bg-surface-container transition-colors" id="nextBtn">arrow_forward</button>
        </div>
      </div>
      <div class="flex gap-4 overflow-x-auto hide-scrollbar snap-x snap-mandatory pb-4" id="carousel">
        {galleryImages.map((src) => (
          <div class="flex-none w-80 md:w-96 snap-start">
            <img class="w-full aspect-square object-cover rounded-xl border border-outline-variant" src={src} alt="Trip photo" />
          </div>
        ))}
      </div>
    </section>

    <section class="mt-stack-lg px-margin-page pb-12">
      <div class="max-w-[1120px] mx-auto">
        <h2 class="font-headline-md text-headline-md text-primary mb-6">Daily Weather</h2>
        <div class="bg-surface-container-low rounded-xl border border-outline-variant p-6 flex flex-wrap items-center gap-8 md:gap-16">
          <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-4xl text-primary">wb_sunny</span>
            <div>
              <p class="font-headline-md text-primary">Mostly Sunny</p>
              <p class="font-label-sm text-on-surface-variant">Brisbane, QLD</p>
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <p class="font-label-sm text-on-surface-variant uppercase tracking-widest">Temperature</p>
            <p class="font-body-lg text-primary font-semibold">High: 24&deg;C / Low: 16&deg;C</p>
          </div>
          <div class="flex flex-col gap-1">
            <p class="font-label-sm text-on-surface-variant uppercase tracking-widest">Wind Speed</p>
            <p class="font-body-lg text-primary font-semibold">4.2 m/s SE</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter-grid mt-stack-lg">
          {navCards.map((card) => (
            <a class="group relative h-48 overflow-hidden rounded-xl border border-outline-variant transition-all hover:shadow-lg" href="#">
              <div class="absolute inset-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-110" style={`background-image: url('${card.image}')`}></div>
              <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent"></div>
              <div class="absolute bottom-4 left-6">
                <p class="font-label-sm text-on-primary-container/80 uppercase tracking-widest mb-1">{card.label}</p>
                <h4 class="font-headline-md text-on-primary">{card.title}</h4>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const carousel = document.getElementById('carousel');
  const nextBtn = document.getElementById('nextBtn');
  const prevBtn = document.getElementById('prevBtn');

  if (carousel && nextBtn) {
    nextBtn.addEventListener('click', () => {
      carousel.scrollBy({ left: 350, behavior: 'smooth' });
    });
  }

  if (carousel && prevBtn) {
    prevBtn.addEventListener('click', () => {
      carousel.scrollBy({ left: -350, behavior: 'smooth' });
    });
  }

  document.querySelectorAll('.calendar-day:not(.muted)').forEach((day) => {
    day.addEventListener('click', () => {
      document.querySelectorAll('.calendar-day').forEach((d) => d.classList.remove('active'));
      day.classList.add('active');
    });
  });
</script>
